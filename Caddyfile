# FrankenPHP configuration for the client Laravel app.
# TLS is terminated by the upstream proxy, so we listen on plain HTTP :8080.
{
	frankenphp
	auto_https off
	admin off
	log {
		output stderr
		format console
	}
}

:8080 {
	root * /app/public

	# Compress responses.
	encode zstd gzip

	# Serve the Laravel front controller. Each request runs in its own
	# goroutine/worker; a PHP fatal error returns 500 for that request only
	# and never crashes the server.
	php_server
}
